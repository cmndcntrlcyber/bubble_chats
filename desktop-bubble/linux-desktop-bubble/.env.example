# Copy to .env and source before running — never commit .env to git

# ── Anthropic (required for Claude models) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (optional — enables local LLM models) ──────────────────────────────
# When both are set, an Ollama option appears in the model dropdown
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Tavily (optional — enables live web search context) ───────────────────────
TAVILY_API_KEY=tvly-...
