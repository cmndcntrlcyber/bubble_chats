# Copy to .env and fill in your values — never commit .env to git

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Use EITHER Anthropic OR Ollama. If OLLAMA_HOST is set, Ollama takes priority.

# Anthropic (default)
# Production (Cloudflare Pages): set as encrypted secret in Pages → Settings → Environment Variables
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Ollama (optional — local LLM, no API key needed)
# For local dev: http://localhost:11434
# For Cloudflare Pages: must be a public URL (tunnel via cloudflared or ngrok)
OLLAMA_HOST=
OLLAMA_MODEL=llama3.2

# ── Other ─────────────────────────────────────────────────────────────────────

# Discord webhook URL for lead delivery (required for /api/contact)
# Create one in your Discord server: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Tavily API key (optional — enables service research context in the chatbot)
# Get one at https://tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# Local dev server port (optional, default: 3000)
PORT=3000
